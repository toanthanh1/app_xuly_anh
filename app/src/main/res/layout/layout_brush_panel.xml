<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/brushPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#222222"
    android:orientation="vertical"
    android:visibility="gone">

    <!-- Stroke width and Color Preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp">

        <SeekBar
            android:id="@+id/seekBrushWidth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="10" />

        <View
            android:id="@+id/btnChooseColor"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_color_picker_button"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Shape Selection -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBrushEraser"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_filter_thumb_selected"
                android:src="@drawable/ic_eraser"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnBrushFree"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_filter_thumb_selected"
                android:src="@drawable/ic_brush"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnBrushArrow"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_filter_thumb_selected"
                android:src="@drawable/ic_arrow_right"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnBrushLine"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_filter_thumb_selected"
                android:src="@drawable/ic_line"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnBrushRect"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_filter_thumb_selected"
                android:src="@drawable/ic_square"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnBrushOval"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_filter_thumb_selected"
                android:src="@drawable/ic_circle"
                android:padding="16dp"
                android:scaleType="fitCenter" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Bottom Actions -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBrushClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:layout_alignParentStart="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Vẽ phác"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/btnBrushDone"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_done"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

</LinearLayout>