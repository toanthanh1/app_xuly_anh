<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    tools:context="com.example.app_xhinh_anh.ui.editor.EditorActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brand_green"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back_arrow"
        app:title=""
        app:titleTextColor="@color/white">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnUndo"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Hoàn tác"
                android:src="@drawable/ic_undo"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnRedo"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Làm lại"
                android:src="@drawable/ic_redo"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Lưu"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <ja.burhanrashid52.photoeditor.PhotoEditorView
        android:id="@+id/photoEditorView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toTopOf="@+id/editorBottomPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <FrameLayout
        android:id="@+id/editorBottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/toolsScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/adjustPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#222222"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <LinearLayout
                        android:id="@+id/tabBrightness"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconBrightness"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Độ sáng"
                            android:src="@drawable/ic_brightness"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelBrightness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Độ sáng"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabContrast"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconContrast"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Tương phản"
                            android:src="@drawable/ic_contrast"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelContrast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Tương phản"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabSaturation"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconSaturation"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Bão hòa"
                            android:src="@drawable/ic_saturation"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelSaturation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Bão hòa"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabSharpness"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconSharpness"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Sắc nét"
                            android:src="@drawable/ic_sharpness"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelSharpness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Sắc nét"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabClarity"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconClarity"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Rõ nét"
                            android:src="@drawable/ic_clarity"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelClarity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rõ nét"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabHsl"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconHsl"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="HSL"
                            android:src="@drawable/ic_hsl"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelHsl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="HSL"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabCurves"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconCurves"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Đường cong"
                            android:src="@drawable/ic_curves"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelCurves"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Đường cong"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabHighlights"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconHighlights"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Vùng sáng"
                            android:src="@drawable/ic_highlights"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelHighlights"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Vùng sáng"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabShadows"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/iconShadows"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Vùng tối"
                            android:src="@drawable/ic_shadows"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/labelShadows"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Vùng tối"
                            android:textColor="@color/white"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/adjustValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.example.app_xhinh_anh.ui.editor.RulerView
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginBottom="-6dp" />

            <SeekBar
                android:id="@+id/seekAdjust"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal"
                android:paddingTop="4dp">

                <Button
                    android:id="@+id/btnAdjustReset"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đặt lại"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btnAdjustApply"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xong"
                    android:textColor="@color/brand_green" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/filterPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#222222"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/filterCategoryTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="2dp" />
            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:background="#333333" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/filterVariantsList"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/filterIntensityValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="100"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.example.app_xhinh_anh.ui.editor.RulerView
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginBottom="-6dp" />

            <SeekBar
                android:id="@+id/filterIntensitySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal"
                android:paddingTop="4dp">

                <Button
                    android:id="@+id/btnFilterReset"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đặt lại"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btnFilterApply"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xong"
                    android:textColor="@color/brand_green" />
            </LinearLayout>
        </LinearLayout>

        <!-- New Text Styling Panel -->
        <LinearLayout
            android:id="@+id/textStylingPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#222222"
            android:orientation="vertical"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="100dp">

                <!-- Text Color Tab -->
                <LinearLayout
                    android:id="@+id/textPanelColor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="visible">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTextColors"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </LinearLayout>

                <!-- Background Color Tab -->
                <LinearLayout
                    android:id="@+id/textPanelBackground"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTextBgColors"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </LinearLayout>

                <!-- Font Tab -->
                <LinearLayout
                    android:id="@+id/textPanelFont"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingTop="8dp">
                        <TextView
                            android:id="@+id/btnStyleBold"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="B"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:background="?attr/selectableItemBackground" />
                        <TextView
                            android:id="@+id/btnStyleItalic"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="I"
                            android:textStyle="italic"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:layout_marginHorizontal="16dp"
                            android:background="?attr/selectableItemBackground" />
                        <TextView
                            android:id="@+id/btnStyleUnderline"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="U"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:background="?attr/selectableItemBackground" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/textFontList"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"/>
                    </HorizontalScrollView>
                </LinearLayout>
            </FrameLayout>

            <!-- Bottom Tabs Bar for Styling -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#111111"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnTextStylingClose"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="#888888" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/tabTextBtnColor"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_palette"
                    app:tint="@color/brand_green" />

                <ImageButton
                    android:id="@+id/tabTextBtnBackground"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_circle"
                    app:tint="#888888" />

                <ImageButton
                    android:id="@+id/tabTextBtnFont"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_font"
                    app:tint="#888888" />

                <ImageButton
                    android:id="@+id/btnTextEditContent"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_text"
                    app:tint="#888888" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/btnTextStylingDone"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_done"
                    app:tint="#888888" />
            </LinearLayout>
        </LinearLayout>

        <include layout="@layout/layout_brush_panel" />
        <include layout="@layout/layout_color_picker" />

    </FrameLayout>

    <HorizontalScrollView
        android:id="@+id/toolsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <LinearLayout
                android:id="@+id/btnCrop"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Cắt"
                    android:src="@drawable/ic_crop"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cắt"
                    android:textColor="@color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFlip"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Lật"
                    android:src="@drawable/ic_flip"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Lật"
                    android:textColor="@color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnAdjust"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Chỉnh"
                    android:src="@drawable/ic_tune"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chỉnh"
                    android:textColor="@color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFilter"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Bộ lọc"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Bộ lọc"
                    android:textColor="@color/white"
